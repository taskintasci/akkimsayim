rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isYonetici() {
      return request.auth != null &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.rol == 'yonetici';
    }

    match /sessions/{sessionId}/rows.json {
      allow read:  if request.auth != null;
      allow write: if isYonetici() && request.resource.size < 30 * 1024 * 1024;
    }
  }
}
