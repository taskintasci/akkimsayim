rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;

      match /results/{rowId} {
        allow read, write: if request.auth != null;
      }

      match /rowChunks/{chunkId} {
        allow read, write: if request.auth != null;
      }
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
